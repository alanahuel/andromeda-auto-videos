# =====================================================================
# Andromeda render-service — example env. Copy to .env and fill in.
# =====================================================================

# ---- API auth ----
# Long random string. Used by Make.com when posting to /jobs.
# Generate with: openssl rand -hex 32
RENDER_API_KEY=changeme_use_a_long_random_string

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Google Drive Service Account ----
# Option A (recommended for Easypanel): provide the JSON as base64.
#   cat sa.json | base64 -w 0
GOOGLE_SERVICE_ACCOUNT_JSON_B64=

# Option B (recommended for local dev with bind-mount): provide a path
# inside the container to the JSON file.
GOOGLE_SERVICE_ACCOUNT_JSON=

# ---- FFmpeg ----
# Hard timeout per ffmpeg invocation, seconds.
FFMPEG_TIMEOUT_SECONDS=600
# How to convert between aspect ratios when source ≠ target: crop | pad
ORIENTATION_STRATEGY=crop

# ---- Worker ----
WORKDIR_BASE=/tmp
# How many jobs the worker process handles in parallel. 1 is correct
# for this VPS — do not raise above 2.
WORKER_CONCURRENCY=1
# Hard timeout per job, seconds (must be ≥ FFMPEG_TIMEOUT_SECONDS).
JOB_TIMEOUT_SECONDS=600

# ---- Logging ----
LOG_LEVEL=INFO
