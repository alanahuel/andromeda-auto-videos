# =====================================================================
# Andromeda render-service — example env. Copy to .env and fill in.
# =====================================================================

# ---- API auth ----
# Long random string. Used by Make.com when posting to /jobs.
# Generate with: openssl rand -hex 32
RENDER_API_KEY=changeme_use_a_long_random_string

# ---- FFmpeg ----
# How to convert between aspect ratios when source ≠ target: crop | pad
ORIENTATION_STRATEGY=crop

# ---- Logging ----
LOG_LEVEL=INFO
