# Copy to docker-compose.override.yml for local development.
# `docker compose` automatically merges this on top of docker-compose.yml.

services:
  api:
    # Mount source so edits hot-reload (uvicorn --reload).
    volumes:
      - ./api/src:/app/src
      - ./shared:/app/shared
    command:
      [
        "uv", "run", "uvicorn",
        "src.main:app",
        "--host", "0.0.0.0",
        "--port", "8000",
        "--reload",
      ]
